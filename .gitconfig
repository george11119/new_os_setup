[init]
	defaultBranch = main
[color]
	ui = auto
[alias]
  st = status
  ci = commit
  br = branch
  co = checkout
  df = diff
  dc = diff --cached
  lg = log -p
  lol = log --graph --decorate --pretty=oneline --abbrev-commit
  lolo = log --graph --decorate --pretty=oneline --abbrev-commit -10
  lola = log --graph --decorate --pretty=oneline --abbrev-commit --all
  ls = ls-files
[core]
	excludesFile = ~/.gitignore

